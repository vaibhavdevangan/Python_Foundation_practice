   "source": [
    "Write a program that removes all non-alpha characters from the given input.\n",
    "\n",
    "Ex: If the input is:\n",
    "-Hello, 1 world$!\n",
    "\n",
    "the output is:\n",
    "Helloworld"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "29533b29",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "-Hello, 1 world$!\n",
      "Hello1world\n"
     ]
    }
   ],
   "source": [
    "in_str = input()\n",
    "new_str = \"\"\n",
    "\n",
    "for i in in_str:\n",
    "    if i.isalpha() or i.isdigit() :\n",
    "        new_str += i\n",
    "\n",
    "print(in_str)\n",
    "print(new_str)"
   ]
  },
